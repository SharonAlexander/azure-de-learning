{
	"name": "pl_ingest_http_to_raw",
	"properties": {
		"activities": [
			{
				"name": "copy_http_to_adls",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "DelimitedTextSource",
						"storeSettings": {
							"type": "HttpReadSettings",
							"requestMethod": "GET"
						},
						"formatSettings": {
							"type": "DelimitedTextReadSettings"
						}
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "ds_http_sales_csv",
						"type": "DatasetReference",
						"parameters": {
							"relative_url": {
								"value": "@pipeline().parameters.p_source_relative_url",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "ds_adls_raw_csv",
						"type": "DatasetReference",
						"parameters": {
							"p_folder": {
								"value": "@concat(pipeline().parameters.p_target_folder, '/', pipeline().parameters.p_load_date)",
								"type": "Expression"
							},
							"p_filename": {
								"value": "@pipeline().parameters.p_target_filename",
								"type": "Expression"
							}
						}
					}
				]
			}
		],
		"parameters": {
			"p_source_relative_url": {
				"type": "string",
				"defaultValue": "/kcncell/Iris_dataset/refs/heads/main/Irisdataset.csv"
			},
			"p_target_folder": {
				"type": "string",
				"defaultValue": "raw"
			},
			"p_target_filename": {
				"type": "string",
				"defaultValue": "iris.csv"
			},
			"p_load_date": {
				"type": "string"
			}
		},
		"annotations": [],
		"lastPublishTime": "2026-05-12T18:25:01Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}